---
---

<div id="header-container">
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const header = document.querySelector('header') as HTMLElement;
      const navLinks = document.querySelectorAll<HTMLElement>('.nav-link');
      const menuIcon = document.querySelector<HTMLElement>('#menu-icon');
      const mobileMenuButton = document.querySelector('#mobile-menu-button');
      const mobileMenu = document.querySelector('#mobile-menu');

      const setScrolled = (scrolled: boolean) => {
        if (scrolled) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      };

      window.addEventListener('scroll', () => setScrolled(window.scrollY > 10));

      if (mobileMenuButton && mobileMenu) {
        mobileMenuButton.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }
    });
  </script>

  <style>
    header.scrolled {
      background-color: white;
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
  </style>

  <header class="fixed top-9 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
    <nav class="container-wide mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-20">
        <div class="flex items-center">
          <a href="/">
            <img src="/quang-minh-logo.svg" alt="Quang Minh Technology Engineering" class="h-10 w-auto" />
          </a>
        </div>

        <div class="hidden lg:flex items-center space-x-8">
          <a href="#" class="nav-link text-gray-800 hover:text-red-600 font-medium transition-colors">Trang Chủ</a>
          <a href="#about" class="nav-link text-gray-800 hover:text-red-600 font-medium transition-colors">Giới Thiệu</a>
          <a href="#solutions" class="nav-link text-gray-800 hover:text-red-600 font-medium transition-colors">Sản Phẩm</a>
          <a href="#projects" class="nav-link text-gray-800 hover:text-red-600 font-medium transition-colors">Dự Án</a>
          <a href="#news" class="nav-link text-gray-800 hover:text-red-600 font-medium transition-colors">Tin Tức</a>
          <a href="#contact" class="ml-6 px-6 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-semibold">
            Liên Hệ
          </a>
        </div>

        <button id="mobile-menu-button" class="lg:hidden">
          <svg id="menu-icon" class="w-6 h-6 text-gray-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <div id="mobile-menu" class="lg:hidden hidden bg-white rounded-xl mt-2 shadow-xl">
        <div class="flex flex-col space-y-1 p-4">
          <a href="#" class="block py-2 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg">Trang Chủ</a>
          <a href="#about" class="block py-2 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg">Giới Thiệu</a>
          <a href="#solutions" class="block py-2 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg">Sản Phẩm</a>
          <a href="#projects" class="block py-2 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg">Dự Án</a>
          <a href="#news" class="block py-2 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg">Tin Tức</a>
          <a href="#contact" class="block py-2 px-4 text-gray-700 hover:text-red-600 hover:bg-gray-50 rounded-lg">Liên Hệ</a>
        </div>
      </div>
    </nav>
  </header>
</div>